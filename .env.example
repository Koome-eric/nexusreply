# ============================================================
# NexusReply v10 — Environment Variables
# Copy this to .env and fill in all values before deploying
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://yourdomain.com"

# ── Google OAuth ─────────────────────────────────────────────
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."

# ── GoHighLevel OAuth ────────────────────────────────────────
GHL_CLIENT_ID="your-ghl-client-id"
GHL_CLIENT_SECRET="your-ghl-client-secret"
GHL_REDIRECT_URI="https://yourdomain.com/api/ghl/oauth/callback"
NEXT_PUBLIC_GHL_CLIENT_ID="your-ghl-client-id"
NEXT_PUBLIC_GHL_REDIRECT_URI="https://yourdomain.com/api/ghl/oauth/callback"

# ── Paystack (Primary — Africa) ──────────────────────────────
# Keys: https://dashboard.paystack.com/#/settings/developer
# Webhook URL to register: https://yourdomain.com/api/billing/paystack-webhook
# Events: charge.success, subscription.not_renew, invoice.payment_failed, subscription.disable
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_xxxxxxxxxxxxxxxx"
# Create plans at: https://dashboard.paystack.com/#/plans
PAYSTACK_STARTER_PLAN_CODE="PLN_xxxxxxxx"
PAYSTACK_PRO_PLAN_CODE="PLN_xxxxxxxx"
PAYSTACK_AGENCY_PLAN_CODE="PLN_xxxxxxxx"

# ── PayPal (Global) ──────────────────────────────────────────
# Credentials: https://developer.paypal.com/dashboard/
# Webhook URL to register: https://yourdomain.com/api/billing/paypal-webhook
# Events: BILLING.SUBSCRIPTION.ACTIVATED, BILLING.SUBSCRIPTION.RENEWED,
#         BILLING.SUBSCRIPTION.PAYMENT.FAILED, BILLING.SUBSCRIPTION.CANCELLED
PAYPAL_CLIENT_ID="ATKNRPPeZuvGed0czUDa54d49o20rp8orD8tcJgs29zz3JpQZucd5PWfbC7ipVKH36z1F7TvD37QlUwC"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="ATKNRPPeZuvGed0czUDa54d49o20rp8orD8tcJgs29zz3JpQZucd5PWfbC7ipVKH36z1F7TvD37QlUwC"
PAYPAL_SECRET="EAS87Fkc9hi3HVOiaDQDsawyMVeiSi0SU1IdjF-FJgy4JgtrERJZWRwaUkbNnpSe8d4HQZH-a6ePR8cy"
PAYPAL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAYPAL_BASE_URL="https://api-m.paypal.com"   # change to https://api-m.paypal.com for production
# Create subscription plans in PayPal Dashboard → Catalog → Products & Plans
PAYPAL_STARTER_PLAN_ID="P-xxxxxxxxxxxxxxxxxxxxxxxx"
PAYPAL_PRO_PLAN_ID="P-xxxxxxxxxxxxxxxxxxxxxxxx"
PAYPAL_AGENCY_PLAN_ID="P-xxxxxxxxxxxxxxxxxxxxxxxx"

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── Local dev overrides (uncomment for local) ────────────────
# NEXTAUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# GHL_REDIRECT_URI="http://localhost:3000/api/ghl/oauth/callback"
# NEXT_PUBLIC_GHL_REDIRECT_URI="http://localhost:3000/api/ghl/oauth/callback"
# PAYPAL_BASE_URL="https://api-m.sandbox.paypal.com"

# ── Role Management (SQL — run once after deploy) ────────────
# Set a user to admin:   UPDATE "User" SET role='admin'  WHERE email='you@email.com';
# Set a user to agency:  UPDATE "User" SET role='agency' WHERE email='you@email.com';
# Roles: admin | agency | user | client
# client role is set automatically when a user accepts an agency invite link
